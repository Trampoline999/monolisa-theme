{
  "name": "monolisa",
  "displayName": "Monolisa",
  "publisher": "onkar-chougule",
  "description": "A beautiful, eye-friendly dark custom theme featuring two variations and custom semantic highlighting for a focused coding experience.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Monolisa",
        "uiTheme": "vs-dark",
        "path": "./themes/monolisa-color-theme.json"
      },
      {
        "label": "Monolisa Modern",
        "uiTheme": "vs-dark",
        "path": "./themes/monolisa-modern-color-theme.json"
      }
    ]
  }
}